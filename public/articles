<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SPORTSrip — Article</title>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --paper:#faf8f3; --paper2:#f3f0e8;
      --ink:#2c2418; --ink2:#4a4030; --ink3:#7a7060;
      --accent:#8b6914; --rule:#d4c9a8;
      --espn-blue:#035bb0; --gold:#f0a500;
    }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { background:var(--paper); color:var(--ink); font-family:'Lora',Georgia,serif; min-height:100vh; display:flex; flex-direction:column; }

    /* ── Header ── */
    .topbar { background:var(--paper2); border-bottom:3px double var(--ink); padding:8px 24px; display:flex; align-items:center; justify-content:space-between; }
    .topbar-logo { font-family:'Lora',serif; font-size:20px; font-weight:700; color:var(--ink); letter-spacing:1px; font-style:italic; text-decoration:none; }
    .topbar-logo span { color:var(--accent); }
    .topbar-right { display:flex; align-items:center; gap:16px; }
    .back-btn { font-family:'Inter',sans-serif; font-size:12px; font-weight:600; color:var(--ink3); text-decoration:none; letter-spacing:0.5px; }
    .back-btn:hover { color:var(--ink); }
    .date-str { font-family:'Inter',sans-serif; font-size:11px; color:var(--ink3); }

    /* ── Page layout ── */
    .page { max-width:1280px; margin:0 auto; width:100%; padding:24px 20px; display:grid; grid-template-columns:200px minmax(0,1fr) 300px; gap:20px; align-items:start; flex:1; }
    .blank-col { }
    .article-wrap { min-width:0; max-width:720px; }

    /* ── Sport category ── */
    .cat-label { font-family:'Inter',sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:2px; color:var(--accent); margin-bottom:14px; }

    /* ── Hero image ── */
    .hero-wrap { width:100%; border-radius:4px; overflow:hidden; margin-bottom:8px; line-height:0; border:3px solid #7B61C4; }
    .hero-img { width:100%; height:auto; display:block; max-height:500px; object-fit:cover; object-position:center 15%; }
    .hero-ph { width:100%; height:280px; display:flex; align-items:center; justify-content:center; font-size:48px; opacity:0.3; }
    .hero-caption { font-family:'Inter',sans-serif; font-size:11px; color:var(--ink3); font-style:italic; margin-bottom:24px; padding-top:6px; }

    /* ── Article title ── */
    .art-title { font-family:'Lora',serif; font-size:28px; font-weight:700; line-height:1.22; color:var(--ink); margin-bottom:14px; }

    /* ── Author bar ── */
    .author-bar { display:flex; align-items:center; gap:10px; padding:12px 0; border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); margin-bottom:24px; }
    .av-img { width:36px; height:36px; border-radius:50%; object-fit:cover; border:2px solid var(--rule); flex-shrink:0; }
    .av-ph { width:36px; height:36px; border-radius:50%; background:var(--accent); color:#fff; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:'Inter',sans-serif; }
    .au-name { font-family:'Inter',sans-serif; font-size:13px; font-weight:600; color:var(--ink); }
    .au-date { font-family:'Inter',sans-serif; font-size:11px; color:var(--ink3); margin-top:1px; }
    .au-right { margin-left:auto; display:flex; align-items:center; gap:6px; }
    .sp-badge { font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--accent); border:1px solid var(--accent); padding:2px 8px; border-radius:3px; }
    .own-badge { font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; background:var(--accent); color:#fff; padding:2px 8px; border-radius:3px; }

    /* ── Body text ── */
    .art-desc { font-family:'Lora',serif; font-size:17px; line-height:1.9; color:var(--ink2); margin-bottom:28px; }

    /* ── Read full article ── */
    .read-btn { display:inline-flex; align-items:center; gap:5px; background:transparent; color:var(--accent); text-decoration:none; padding:6px 14px; border:1.5px solid var(--accent); border-radius:4px; font-family:'Inter',sans-serif; font-size:12px; font-weight:600; letter-spacing:0.5px; transition:0.2s; margin-bottom:28px; }
    .read-btn:hover { background:var(--accent); color:#fff; }

    /* ── Related strip ── */
    .related-sec { border-top:2px solid var(--rule); padding-top:20px; }
    .sec-label { font-family:'Inter',sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:2px; color:var(--ink3); margin-bottom:16px; }
    .strip-wrap { position:relative; padding:0 22px; }
    .arr-btn { position:absolute; top:35%; transform:translateY(-50%); width:32px; height:32px; border-radius:50%; background:var(--paper2); border:1px solid var(--rule); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:14px; color:var(--ink); transition:0.2s; }
    .arr-btn:hover { background:var(--accent); color:#fff; border-color:var(--accent); }
    .arr-btn.l { left:0; } .arr-btn.r { right:0; }
    .rel-strip { display:flex; gap:12px; overflow-x:auto; padding-bottom:10px; scroll-behavior:smooth; scrollbar-width:none; }
    .rel-strip::-webkit-scrollbar { display:none; }
    .rel-card { flex-shrink:0; width:200px; background:#f3f0e8; border-radius:4px; overflow:hidden; text-decoration:none; color:#2c2418; border:1px solid #d4c9a8; transition:0.2s; }
    .rel-card:hover { border-color:#8b6914; box-shadow:0 3px 12px rgba(0,0,0,0.08); }
    .rel-img { width:100%; height:110px; object-fit:cover; display:block; }
    .rel-img-ph { width:100%; height:110px; background:#f3f0e8; display:flex; align-items:center; justify-content:center; font-size:20px; opacity:0.3; }
    .rel-body { padding:10px; background:#f3f0e8; }
    .rel-src { font-family:'Inter',sans-serif; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#8b6914; margin-bottom:4px; }
    .rel-title { font-family:'Lora',serif; font-size:13px; line-height:1.4; color:#2c2418; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }

    /* ── Sidebar ── */
    .sidebar { display:flex; flex-direction:column; gap:14px; position:sticky; top:20px; }
    .promo-img { width:100%; height:auto; display:block; border-radius:4px; border:1px solid var(--rule); margin-top:46px; }
    .sb-divider { border:none; border-top:2px solid var(--rule); }
    .sb-title { font-family:'Inter',sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:2px; color:var(--ink3); padding:10px 0 14px; }
    .sb-card { display:block; text-decoration:none; color:inherit; padding-bottom:16px; margin-bottom:16px; border-bottom:1px solid var(--rule); transition:0.15s; }
    .sb-card:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
    .sb-card:hover .sb-ttl { color:var(--accent); }
    .sb-img { width:100%; height:auto; display:block; border-radius:3px; margin-bottom:8px; border:1px solid var(--rule); }
    .sb-src { font-family:'Inter',sans-serif; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--accent); margin-bottom:4px; }
    .sb-ttl { font-family:'Lora',serif; font-size:14px; font-weight:600; line-height:1.4; margin-bottom:4px; transition:0.2s; }
    .sb-date { font-family:'Inter',sans-serif; font-size:10px; color:var(--ink3); }

    .spin { text-align:center; padding:28px; color:var(--ink3); font-family:'Inter',sans-serif; font-size:12px; font-style:italic; }
    @keyframes pulse { 0%,100%{opacity:.4} 50%{opacity:1} }
    .spin { animation:pulse 1.4s infinite; }

    footer { padding:14px 24px; background:var(--paper2); border-top:1px solid var(--rule); text-align:center; margin-top:auto; }
    .disc { font-family:'Inter',sans-serif; font-size:10px; color:var(--ink3); max-width:800px; margin:0 auto; font-style:italic; }

    @media(max-width:1000px){ .page { grid-template-columns:minmax(0,1fr) 260px; gap:20px; } .blank-col { display:none; } }
    @media(max-width:660px){ .page { grid-template-columns:1fr; padding:16px 14px; } .sidebar { display:none; } .art-title { font-size:22px; } }
  </style>
</head>
<body>

<div class="topbar">
  <a href="/" class="topbar-logo"><span>SPORTS</span>rip</a>
  <div class="topbar-right">
    <span class="date-str" id="dateStr"></span>
    <a href="/" class="back-btn">← Back</a>
  </div>
</div>

<div class="page">
  <div class="blank-col"></div>
  <main class="article-wrap" id="articleMain"><div class="spin">Loading article...</div></main>
  <aside class="sidebar">
    <img class="promo-img" src="https://images.pexels.com/photos/8941571/pexels-photo-8941571.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Kids Sports">
    <hr class="sb-divider">
    <div>
      <div class="sb-title">Our Articles</div>
      <div id="sbList"><div class="spin">Loading...</div></div>
    </div>
  </aside>
</div>

<footer>
  <div class="disc" id="personalDisc" style="display:none;margin-bottom:8px;font-size:11px;font-style:italic;color:var(--ink2);border-bottom:1px solid var(--rule);padding-bottom:8px;">
    ✍️ This blog reflects my personal take and passion for sports, shared purely from a fan's perspective.
  </div>
  <div class="disc">Disclaimer: Headlines are sourced from official RSS feeds of their respective publishers. All rights and copyrights remain with the original content owners.</div>
</footer>

<script>
  var WORKER = 'https://mango-sports-worker-dev.ravi-kompel.workers.dev';
  var ADMIN_PASS = 'sportsrip2026';
  var DEFAULT_AUTHOR = 'SPORTSrip Team';
  var DEFAULT_PHOTO  = '';

  var EMOJI = {ipl:'🏏',f1:'🏎️',cricket:'🏏',basketball:'🏀',football:'⚽',baseball:'⚾',tennis:'🎾',kabaddi:'🤼',boxing:'🥊',golf:'⛳',athletics:'🏃',rugby:'🏉',olympics:'🏅',nfl:'🏈',badminton:'🏸'};
  var LABEL = {ipl:'IPL 2026',f1:'Formula 1',cricket:'Cricket',basketball:'NBA',football:'Soccer',baseball:'MLB',tennis:'Tennis',kabaddi:'Kabaddi',boxing:'Boxing',golf:'Golf',athletics:'Athletics',rugby:'Rugby',olympics:'Olympics',nfl:'NFL',badminton:'Badminton'};

  document.getElementById('dateStr').textContent = new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});

  function san(s){ var d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }
  function fdate(iso){ try{ return new Date(iso).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'}); }catch(_){return '';} }
  function scrollRel(d){ var s=document.getElementById('relStrip'); if(s) s.scrollBy({left:d*640,behavior:'smooth'}); }

  function renderArticle(a) {
    var sport=a.sport||'ipl', emoji=EMOJI[sport]||'', label=LABEL[sport]||sport.toUpperCase();
    var isOwn=a.isOwn||a.source==='SPORTSrip';
    var author=(a.authorName&&a.authorName.trim())?a.authorName:(isOwn?DEFAULT_AUTHOR:(a.source||'SPORTSrip'));
    var photo=(a.authorPhoto&&a.authorPhoto.trim())?a.authorPhoto:DEFAULT_PHOTO;
    var init=author.split(' ').map(function(w){return w[0]||'';}).join('').toUpperCase().slice(0,2)||'SR';

    var av=photo
      ?'<img class="av-img" src="'+san(photo)+'" onerror="this.outerHTML=\'<div class=av-ph>'+san(init)+'</div>\'">'
      :'<div class="av-ph">'+san(init)+'</div>';

    var hero=a.image
      ?'<div class="hero-wrap"><img class="hero-img" src="'+san(a.image)+'" alt="'+san(a.title)+'"></div><div class="hero-caption">'+san(label)+' · '+fdate(a.pubDate)+'</div>'
      :'';

    document.getElementById('articleMain').innerHTML=
      '<div class="cat-label">'+emoji+' '+san(label)+(isOwn?' &nbsp;<strong style="font-size:12px;color:var(--ink);letter-spacing:1px;font-family:Inter,sans-serif;">· My Take</strong>':'')+'</div>'+
      hero+
      '<div class="art-title">'+san(a.title)+'</div>'+
      '<div class="author-bar">'+av+
        '<div><div class="au-name">'+san(author)+'</div><div class="au-date">'+fdate(a.pubDate)+'</div></div>'+
        '<div class="au-right"><span class="sp-badge">'+san(label)+'</span>'+(isOwn?'<span class="own-badge">SPORTSrip</span>':'')+'</div>'+
      '</div>'+
      (a.description?'<div class="art-desc">'+san(a.description)+'</div>':'')+
      ((!a.link||a.isOwn||a.link.indexOf('sportsrip.com')>-1)?'':'<a href="'+san(a.link)+'" target="_blank" rel="noopener noreferrer" class="read-btn">Read Full Article →</a>')+
      '<div class="related-sec">'+
        '<div class="sec-label">Related Articles</div>'+
        '<div class="strip-wrap">'+
          '<button class="arr-btn l" onclick="scrollRel(-1)">&#8592;</button>'+
          '<div class="rel-strip" id="relStrip"><div class="spin">Loading...</div></div>'+
          '<button class="arr-btn r" onclick="scrollRel(1)">&#8594;</button>'+
        '</div>'+
      '</div>';

    document.title='SPORTSrip — '+a.title.slice(0,60);
    // Show personal disclaimer only for own articles
    var pd = document.getElementById('personalDisc');
    if(pd) pd.style.display = isOwn ? 'block' : 'none';
    loadRelated(sport,a.link);
  }

  async function loadRelated(sport,currentLink){
    try{
      var res=await fetch(WORKER+'/api/news?sport='+sport);
      var data=await res.json();
      var arts=(data.articles||[]).filter(function(a){return a.link!==currentLink;});
      var list=arts.filter(function(a){return a.isOwn;}).concat(arts.filter(function(a){return !a.isOwn;})).slice(0,15);
      var strip=document.getElementById('relStrip');
      if(!list.length){strip.innerHTML='<div style="color:var(--ink3);font-size:11px;font-style:italic;padding:8px">No related articles.</div>';return;}
      strip.innerHTML='';
      list.forEach(function(a){
        var c=document.createElement('a'); c.className='rel-card';
        if(a.isOwn){c.href='articles.html?data='+encodeURIComponent(JSON.stringify(a));c.target='_self';}
        else{c.href=a.link;c.target='_blank';c.rel='noopener noreferrer';}
        var img=a.image?'<img class="rel-img" src="'+san(a.image)+'" loading="lazy" onerror="this.style.display=\'none\'">':'<div class="rel-img-ph">'+(EMOJI[a.sport]||'')+'</div>';
        c.innerHTML=img+'<div class="rel-body"><div class="rel-src">'+(a.isOwn?'SPORTSrip':san(a.source||''))+'</div><div class="rel-title">'+san(a.title)+'</div></div>';
        strip.appendChild(c);
      });
    }catch(e){var s=document.getElementById('relStrip');if(s)s.innerHTML='<div style="color:var(--ink3);font-size:11px;font-style:italic">Could not load.</div>';}
  }

  // ── Sidebar: fetch own articles from each sport ──
  async function loadSidebar(){
    try{
      var sports=['ipl','cricket','football','f1','basketball','tennis','boxing','golf','badminton','kabaddi'];
      var seen=new Set(); var unique=[];

      // Fetch all sports in parallel
      var results = await Promise.allSettled(sports.map(function(sp){
        return fetch(WORKER+'/api/news?sport='+sp).then(function(r){return r.json();});
      }));

      results.forEach(function(r){
        if(r.status==='fulfilled'){
          (r.value.articles||[]).filter(function(a){return a.isOwn;}).forEach(function(a){
            if(!seen.has(a.link)){seen.add(a.link);unique.push(a);}
          });
        }
      });

      var box=document.getElementById('sbList');
      if(!unique.length){box.innerHTML='<div style="color:var(--ink3);font-size:11px;font-style:italic;padding:8px">No articles yet.</div>';return;}

      unique.sort(function(a,b){return new Date(b.pubDate)-new Date(a.pubDate);});
      box.innerHTML='';
      unique.forEach(function(a){
        var el=document.createElement('a'); el.className='sb-card';
        el.href='articles.html?data='+encodeURIComponent(JSON.stringify(a));
        var img=a.image?'<img class="sb-img" src="'+san(a.image)+'" onerror="this.style.display=\'none\'">':'';
        el.innerHTML=img+'<div class="sb-src">SPORTSrip</div><div class="sb-ttl">'+san(a.title)+'</div><div class="sb-date">'+fdate(a.pubDate)+'</div>';
        box.appendChild(el);
      });
    }catch(e){document.getElementById('sbList').innerHTML='<div style="color:var(--ink3);font-size:11px;font-style:italic;padding:8px">Could not load.</div>';}
  }

  (function(){
    var raw=new URLSearchParams(window.location.search).get('data');
    if(raw){try{renderArticle(JSON.parse(decodeURIComponent(raw)));}catch(e){document.getElementById('articleMain').innerHTML='<div class="spin">Could not load. <a href="/" style="color:var(--accent)">Go home</a></div>';}}
    else{document.getElementById('articleMain').innerHTML='<div class="spin">No article found. <a href="/" style="color:var(--accent)">Go home</a></div>';}
    loadSidebar();
  })();
</script>
</body>
</html>
